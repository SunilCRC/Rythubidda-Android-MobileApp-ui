# Rythu Bidda Mobile — environment variables
# Copy this file to `.env` (and `.env.production`) and fill in values.

# Backend API base URL (no trailing slash).
# Production default is the public host. Devs working against a local
# Spring Boot should override in their own `.env` to e.g.
# `http://192.168.x.x:8080` (HTTP, since local dev doesn't run TLS).
API_BASE_URL=https://rythubidda.com

# HTTP timeout in milliseconds
API_TIMEOUT_MS=30000

# Environment name (development | staging | production)
ENV=development

# Google Maps API key — used for Geocoding API + Places API + Maps SDK Android.
# Generate at https://console.cloud.google.com → APIs & Services → Credentials.
# Restrict the key to:
#   - Android apps with package "com.rythubiddamobile" + your debug/release SHA-1
#   - APIs: Geocoding, Places, Maps SDK Android (and ONLY these)
# IMPORTANT: this key is bundled into the APK at build time. Never reuse a key
# that has access to billing-sensitive APIs (Distance Matrix, Directions, etc.).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
