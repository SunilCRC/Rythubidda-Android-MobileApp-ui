# ─────────────────────────────────────────────────────────────────────────
#  Rythu Bidda Mobile — environment variables
#  Copy this file to `.env` and uncomment the line that matches your setup.
# ─────────────────────────────────────────────────────────────────────────

# ── Backend API base URL (no trailing slash) ─────────────────────────────
# PRODUCTION (default):
API_BASE_URL=https://rythubidda.com

# LOCAL DEV — Android EMULATOR:
#   10.0.2.2 is a special alias the Android emulator maps to the host
#   machine's localhost. Use this when running the Spring Boot backend on
#   the same PC as the emulator.
# API_BASE_URL=http://192.168.29.82:8080

# LOCAL DEV — Physical phone on same Wi-Fi:
#   Replace with your dev PC's actual LAN IP (run `ipconfig` on Windows or
#   `ifconfig`/`ip a` on Mac/Linux to find it).
# API_BASE_URL=http://192.168.29.82:8080

# ── HTTP timeout in milliseconds ─────────────────────────────────────────
API_TIMEOUT_MS=30000

# ── Environment label (development | staging | production) ───────────────
# Drives __DEV__ logging + a couple of UI hints. Doesn't change which
# backend is hit — that's controlled entirely by API_BASE_URL above.
ENV=development

# ── Google Maps API key ──────────────────────────────────────────────────
# Used for: Geocoding API, Places API (New), Maps SDK Android.
# Restrict the key in Google Cloud Console to:
#   • Android apps → package "com.rythubiddamobile" + your debug/release SHA-1
#   • API restrictions → only the 3 APIs above
# IMPORTANT: this key is bundled into the APK at build time. Never reuse a
# key with access to billing-sensitive APIs (Distance Matrix, Directions).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
